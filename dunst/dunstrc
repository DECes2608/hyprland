[global]
    ### Display ###
    monitor = 0
    follow = none

    ### Geometry ###
    width = 350
    height = 300
    origin = top-right
    offset = 10x50
    scale = 0
    notification_limit = 0

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    text_icon_padding = 10

    # Çerçeve rengi: Saf Beyaz
    frame_width = 2
    frame_color = "#ffffff"

    gap_size = 0
    separator_color = frame
    sort = yes

    ### Text ###
    font = "FantasqueSansM Nerd Font Mono 11"
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark
    icon_position = left
    min_icon_size = 32
    max_icon_size = 128

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/rofi -dmenu -p 
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 10
    ignore_dbusclose = false

    ### Wayland ###
    force_xwayland = false

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    # Düşük öncelik: Koyu gri arka plan, gri metin
    background = "#111111"
    foreground = "#888888"
    timeout = 5

[urgency_normal]
    # Normal öncelik: Siyah arka plan, beyaz metin
    background = "#111111"
    foreground = "#ffffff"
    timeout = 5

[urgency_critical]
    # Kritik öncelik: Beyaz arka plan, siyah metin (Dikkat çekmesi için tersine çevrildi)
    background = "#ffffff"
    foreground = "#000000"
    frame_color = "#ffffff"
    timeout = 0

[play_sound]
    msg_urgency = normal
    script = ~/.local/bin/noti.sh
