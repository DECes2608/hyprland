{
  "layer": "top",
  "position": "top",
  "mode": "dock",
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "height": 0,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "network", "pulseaudio", "tray"],

  "hyprland/window": {
    "format": "󰣇  {}",
    "max-length": 40,
    "separate-outputs": true
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate"
  },

  "clock": {
    "format": "  {:%H:%M}",
    "format-alt": "  {:%d %b %Y}",
    "interval": 1,
    "tooltip": false
  },

  "tray": {
    "icon-size": 13,
    "spacing": 12
  },

  "cpu": {
    "interval": 5,
    "format": "󰍛 {usage}%"
  },

  "memory": {
    "interval": 10,
    "format": "󰾆 {used:0.1f}G",
    "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB"
  },

  "network": {
    "interval": 2,
    "format-wifi": "  {essid}",
    "format-ethernet": "󰈀  {ifname}",
    "format-disconnected": "󰖪  Yok",
    "tooltip-format": "{ifname} — {ipaddr}\n{essid} ({signalStrength}%)"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟  Sessiz",
    "tooltip": false,
    "on-click": "pamixer -t",
    "on-scroll-up": "pamixer -i 2",
    "on-scroll-down": "pamixer -d 2",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    }
  }
}
